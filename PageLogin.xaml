<Page x:Class="Chop_chOp.PageLoginss"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Chop_chOp"
      mc:Ignorable="d" 
      d:DesignHeight="350" d:DesignWidth="800"
      Title="PageLogin">

    <Grid>


        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width ="200" >
            <TextBlock Text="Логин:" />
            <TextBox x:Name="LoginInput"/>
            <TextBlock Text="Пароль:"  />
            <PasswordBox PasswordChar="*" x:Name="PasswordInput"/>
            <DockPanel>
                <Button x:Name="Login" DockPanel.Dock="Left" Content="Войти" Margin="5" Width="100" Click="Login_Click"/>
                <Button x:Name="Reg" DockPanel.Dock="Right" Content="Регистрация" Margin="5" Click="Reg_Click"  />
            </DockPanel>
            
        </StackPanel>

    </Grid>
</Page>
