<Window x:Class="Chop_chOp.WindowAddStudent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chop_chOp"
        mc:Ignorable="d"
        Title="WindowAddStudent" Height="450" Width="800">
    <Grid>
        <TextBlock Text="ДОБАВЛЕНИЕ СТУДЕНТА" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="25"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width ="200" >
            <TextBlock Text="Имя:" />
            <TextBox x:Name="NameInput"/>
            <TextBlock Text="Логин:" />
            <TextBox x:Name="LoginInput"/>
            <TextBlock Text="Пароль:"  />
            <PasswordBox PasswordChar="*" x:Name="PasswordInput"/>
            <TextBlock Text="Повторите пароль"/>
            <PasswordBox PasswordChar="*" x:Name="PasswordRepeat"/>
            <DockPanel>
                <RadioButton GroupName="Role" Content="Ученик" Margin="5" IsChecked="True"/>
                <RadioButton x:Name="IsAdmin"  GroupName="Role" Content="Администратор" Margin="5"/>
            </DockPanel>
            <DockPanel>
                <Button x:Name="Reg" DockPanel.Dock="Left" Content="Создать" Margin="5" Width="100" Click="Reg_Click" />
                <Button x:Name="Back" DockPanel.Dock="Right" Content="Назад" Margin="5" Click="Back_Click"  />
            </DockPanel>

        </StackPanel>

    </Grid>
</Window>
