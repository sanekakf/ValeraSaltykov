<Page x:Class="Chop_chOp.PageAdmin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Chop_chOp"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageAdmin">

    <Grid>
        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Text="ПАНЕЛЬ АДМИНИСТРАТОРА" FontSize="25"/>
        <TextBlock x:Name="hello" HorizontalAlignment="Center" Text="ПРИВЕТСВУЕМ ВАС" Margin="55"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width ="200">
            <Button x:Name="addStudent" Margin="5" Content="Добавить студента" Click="addStudent_Click"/>
            <Button x:Name="listStudents" Margin="5" Content="Список студентов" Click="listStudents_Click"/>
            <Button x:Name="back" Margin="5" Content="Назад" Click="back_Click"/>
        </StackPanel>
    </Grid>
</Page>
