<Window x:Class="Chop_chOp.WindowOrders"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chop_chOp"
        mc:Ignorable="d"
        Title="WindowOrders" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <DockPanel Height="50">
                <Label FontSize="18" Content="ID ЗАКАЗА:" HorizontalAlignment="Center"/>
                <TextBox FontSize="18" Width="300" HorizontalAlignment="Center" x:Name="id"/>
                <Button x:Name="search" FontSize="18" Width="200" HorizontalAlignment="Right" Content="Найти" Click="search_Click"/>
            </DockPanel>
            <DockPanel Margin="0,5,0,0">
                <Label Width="auto" FontSize="15" HorizontalAlignment="Center" Content="ID заказа"/>
                <Border Width="1" Background="Black"/>
                <Label Width="auto" FontSize="15" HorizontalAlignment="Center" Content="ФИО заказчика"/>
                <Border Width="1" Background="Black"/>
                <Label Width="auto" FontSize="15" HorizontalAlignment="Center" Content="Наименование товара"/>
                
            </DockPanel>
            <ListBox Margin="0,15,0,0" x:Name="orderList" SelectionChanged="orderList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="15" Width="auto" Height="auto">
                            <TextBlock FontSize="15" Width="auto" Text="{Binding Path=Id}"/>
                            <Border Margin="5" Width="1" Background="Black"/>

                            <TextBlock FontSize="15" Width="auto" Text="{Binding Path=Name}"/>
                            <Border Margin="5" Width="1" Background="Black"/>
                            <TextBlock FontSize="15" Width="auto" Text="{Binding Path=Description}"/>
                        </DockPanel>

                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </StackPanel>
    </Grid>
</Window>
