<Page x:Class="Chop_chOp.PageReg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Chop_chOp"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageReg">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width ="200" >
            <TextBlock Text="Имя:" />
            <TextBox x:Name="NameInput"/>
            <TextBlock Text="Логин:" />
            <TextBox x:Name="LoginInput"/>
            <TextBlock Text="Пароль:"  />
            <PasswordBox PasswordChar="*" x:Name="PasswordInput"/>
            <TextBlock Text="Повторите пароль"/>
            <PasswordBox PasswordChar="*" x:Name="PasswordRepeat"/>
            <DockPanel>
                <Button x:Name="Reg" DockPanel.Dock="Left" Content="Создать" Margin="5" Width="100" Click="Reg_Click" />
                <Button x:Name="Back" DockPanel.Dock="Right" Content="Назад" Margin="5" Click="Back_Click"  />
            </DockPanel>

        </StackPanel>

    </Grid>
</Page>
