<Page x:Class="Chop_chOp.PageProducts"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Chop_chOp"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageProducts">

    <Page.Resources>
        <local:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
    </Page.Resources>

    <Grid>
        <StackPanel>
            <Button x:Name="addProd" Content="ДОБАВИТЬ НОВЫЙ ТОВАР" Click="addProd_Click"/>
            <ListBox x:Name="productsList" SelectionChanged="productsList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <DockPanel Margin="5" Width="auto" Height="auto">
                        <Image Margin="0,0,25,0" Source="{Binding Path=img, Converter={StaticResource ByteArrayToImageConverter}}" Width="250" Height="250" HorizontalAlignment="Left" />
                        <StackPanel>
                            <Label FontSize="20" Content="{Binding Path=Description}" HorizontalAlignment="Center" />
                            <Label FontSize="16" Content="{Binding Path=Type}"/>
                            <Label FontSize="16" Content="{Binding Path=Manufacturer}"/>
                            <Label FontSize="16" Content="{Binding Path=Supplier}"/>
                        </StackPanel>
                        <StackPanel Width="auto">
                            <Label HorizontalAlignment="Center" FontSize="25" Content="{Binding Path=Price}" Foreground="Red"/>
                            <Label HorizontalAlignment="Right" VerticalAlignment="Bottom" Content="{Binding Path=Remains}"/>
                        </StackPanel>
                    </DockPanel>

                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        </StackPanel>
    </Grid>
</Page>
