<Page x:Class="Chop_chOp.PageStudent"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Chop_chOp"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageStudent">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width ="Auto" >
            <TextBlock x:Name="Name" Margin="5" FontSize="20"/>
            <TextBlock x:Name="Login" Margin="5" FontSize="20"/>

        </StackPanel>

    </Grid>
</Page>
