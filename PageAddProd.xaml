<Page x:Class="Chop_chOp.PageAddProd"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Chop_chOp"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="800"
      Title="PageAddProd">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="113*"></RowDefinition>
            <RowDefinition Height="138*"></RowDefinition>
            <RowDefinition Height="105*"></RowDefinition>
            <RowDefinition Height="95*"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>

        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="4" Grid.Row="3" Margin="0,1,0,0"/>
        <Label Grid.Column="1" Grid.ColumnSpan="3" HorizontalAlignment="Center" Content="ДОБАВЛЕНИЕ ТОВАРА" VerticalAlignment="Center" Width="218" FontSize="20" Height="37"/>
        <TextBlock x:Name="help" HorizontalAlignment="Left" MouseDown="addPicture_MouseDown" Grid.Row="1" TextWrapping="Wrap" Text="Нажмите что бы добавить картинку" VerticalAlignment="Top" Height="32" Width="146" Margin="4,2,0,0"/>
        <Image  x:Name="addPicture" MouseDown="addPicture_MouseDown" Grid.Column="0" HorizontalAlignment="Left" Width="475" Margin="0,225,0,5" Grid.ColumnSpan="3" Grid.RowSpan="2" />

        <StackPanel Grid.Column="3" Grid.RowSpan="1" Grid.Row="1" Margin="0,0,15,0">
            <Label Content="Название товара:" HorizontalAlignment="Left"/>
            <TextBox x:Name="Name" HorizontalAlignment="Left" Width="200"/>
            <Label Margin="0,15,0,0" Content="Цена:" HorizontalAlignment="Left"/>
            <TextBox x:Name="Price" HorizontalAlignment="Left" Width="200"/>

            <Label Margin="0,15,0,0" Content="Количество:" HorizontalAlignment="Left"/>
            <TextBox Margin="0,0,0,15" x:Name="Remain" HorizontalAlignment="Left" Width="200"/>
        </StackPanel>
        <StackPanel Grid.Column="4" Grid.Row="1">
            <Label Content="Категория товара:" HorizontalAlignment="Left"/>
            <ComboBox  x:Name="ProdCategory" />
            <Label Margin="0,5,0,0" Content="Тип товара:" HorizontalAlignment="Left"/>
            <ComboBox  x:Name="ProdType" />
            <Label Margin="0,5,0,0" Content="Производитель"  HorizontalAlignment="Left"/>
            <ComboBox  x:Name="Manufacturer" />
            <Label Content="Поставщик" HorizontalAlignment="Left"/>
            <ComboBox  x:Name="Supplier" />
        </StackPanel>
        <Button x:Name="SEND" Grid.Column="3" Grid.Row="4" Width="auto" Content="Добавить" Height="40" Click="SEND_Click" />
    </Grid>
</Page>
